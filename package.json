{
  "name": "bahor-voyage",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "design:lint": "npx @google/design.md lint DESIGN.md",
    "design:spec": "npx @google/design.md spec --rules",
    "design:export": "npx @google/design.md export --format dtcg DESIGN.md > design-tokens.json",
    "prepare": "husky",
    "db:push": "prisma db push",
    "db:studio": "NODE_NO_WARNINGS=1 prisma studio --port 5555",
    "db:generate": "prisma generate",
    "admin:create": "node scripts/create-admin-user.js"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@stripe/stripe-js": "^5.5.0",
    "@types/pg": "^8.20.0",
    "bcryptjs": "^3.0.3",
    "framer-motion": "^12.38.0",
    "jspdf": "^4.2.1",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "next-intl": "^4.8.3",
    "nodemailer": "^7.0.13",
    "pg": "^8.20.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "stripe": "^22.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prisma": "^7.7.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings=0 --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
